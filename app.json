{
  "expo": {
    "name": "말로",
    "slug": "mallo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "mallo",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.danielpark.mallo",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "음성 메모를 녹음하기 위해 마이크 접근 권한이 필요합니다.",
        "NSSpeechRecognitionUsageDescription": "말씀하신 내용을 텍스트로 변환하기 위해 음성 인식 권한이 필요합니다."
      }
    },
    "android": {
      "package": "com.danielpark.mallo",
      "adaptiveIcon": {
        "backgroundColor": "#0b0b1c",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-audio",
      "expo-speech-recognition"
    ]
  }
}
